ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=                                # leave empty → stat-reviewer skips

TYPO_API_BASE_URL=http://localhost:8000         # server-side only (Next route handlers)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEMO_USER_ID=demo

# LUME_DB_PATH is OPTIONAL. If unset, code defaults to repo_root / "services/typo/seed.db".
# LUME_DB_PATH=

# LUME_REPO_ROOT is OPTIONAL. If unset, code walks up from CWD looking for pnpm-workspace.yaml.
# LUME_REPO_ROOT=

LUME_COLLECT_MODE=                              # set to "real_user" for Phase 5.1 to force random arms

LUME_HASH_SALT=                                 # required for real-user HMAC text identifiers
